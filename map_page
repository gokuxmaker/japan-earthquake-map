<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=800"/>
<title>Japan Earthquake Monitor</title>
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@700;900&family=Exo+2:wght@800;900&display=swap" rel="stylesheet"/>
<style>
*{box-sizing:border-box;margin:0;padding:0}
html,body{width:800px;height:480px;overflow:hidden;background:#fff;font-family:'Exo 2',sans-serif;color:#000}
.page{width:800px;height:480px;display:grid;grid-template-columns:320px 1fr;border:4px solid #000}
 
.map-panel{border-right:3px solid #000;display:flex;flex-direction:column;background:#fff}
.map-header{background:#000;color:#fff;padding:8px 12px;display:flex;align-items:center;justify-content:space-between;flex-shrink:0}
.map-title{font-family:'Orbitron',monospace;font-size:12px;font-weight:900;letter-spacing:2px}
.map-time{font-size:11px;font-weight:800;color:#ccc;letter-spacing:1px}
.map-wrap{flex:1;position:relative;overflow:hidden;background:#fff}
.map-img{width:100%;height:100%;object-fit:contain;filter:invert(1);display:block}
 
#epi-ring{position:absolute;width:36px;height:36px;border-radius:50%;border:3px solid #000;transform:translate(-50%,-50%);pointer-events:none;display:none}
#epi-marker{position:absolute;width:26px;height:26px;transform:translate(-50%,-50%);pointer-events:none;display:none}
#epi-marker::before{content:'';position:absolute;background:#000;width:3px;height:26px;left:50%;top:0;transform:translateX(-50%)}
#epi-marker::after{content:'';position:absolute;background:#000;width:26px;height:3px;top:50%;left:0;transform:translateY(-50%)}
#epi-center{position:absolute;width:10px;height:10px;border-radius:50%;background:#000;transform:translate(-50%,-50%);pointer-events:none;display:none}
 
.map-footer{padding:5px 10px;border-top:2.5px solid #000;font-size:11px;font-weight:900;color:#000;flex-shrink:0;background:#fff;display:flex;gap:14px;align-items:center}
 
.data-panel{background:#fff;display:flex;flex-direction:column}
.data-header{background:#000;color:#fff;padding:8px 14px;display:flex;align-items:center;justify-content:space-between;flex-shrink:0}
.monitor-label{font-family:'Orbitron',monospace;font-size:11px;font-weight:900;letter-spacing:3px}
.live-badge{font-family:'Orbitron',monospace;font-size:11px;font-weight:900;display:flex;align-items:center;gap:6px}
.live-dot{width:10px;height:10px;border-radius:50%;background:#fff;border:2px solid #888}
 
.main-quake{padding:10px 14px;border-bottom:3px solid #000;flex-shrink:0}
.mag-row{display:flex;align-items:baseline;gap:8px;margin-bottom:3px}
.mag-label{font-size:12px;font-weight:900;letter-spacing:2px;text-transform:uppercase}
.mag-value{font-family:'Orbitron',monospace;font-size:54px;font-weight:900;color:#000;line-height:1}
.mag-unit{font-family:'Orbitron',monospace;font-size:16px;font-weight:900}
.quake-location{font-size:16px;font-weight:900;color:#000;margin-bottom:3px;line-height:1.25}
.quake-meta{display:flex;gap:14px}
.quake-time,.quake-depth{font-size:13px;font-weight:900;color:#000}
 
.scale-section{padding:8px 14px;border-bottom:3px solid #000;flex-shrink:0}
.section-label{font-size:10px;font-weight:900;letter-spacing:3px;text-transform:uppercase;margin-bottom:6px}
.scale-bar{display:flex;height:20px;border:2.5px solid #000;border-radius:2px;overflow:hidden}
.scale-seg{display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:900;color:#fff;flex:1}
 
.recent-section{flex:1;display:flex;flex-direction:column;overflow:hidden}
.recent-label{padding:7px 14px 5px;font-size:10px;font-weight:900;letter-spacing:3px;text-transform:uppercase;border-bottom:2px solid #000;flex-shrink:0}
.quake-list{flex:1;display:flex;flex-direction:column;justify-content:space-between;padding:5px 14px 8px}
.q-row{display:flex;align-items:center;gap:8px;padding:3px 0;border-bottom:1.5px solid #ccc}
.q-row:last-child{border-bottom:none}
.q-mag{font-family:'Orbitron',monospace;font-size:20px;font-weight:900;width:46px;flex-shrink:0}
.q-info{flex:1}
.q-loc{font-size:13px;font-weight:900;color:#000;line-height:1.2}
.q-sub{font-size:11px;font-weight:800;color:#333;display:flex;gap:10px}
.q-mbar{width:56px;flex-shrink:0}
.q-mbar-track{height:10px;border:2px solid #000;border-radius:2px;overflow:hidden;background:#eee}
.q-mbar-fill{height:100%;background:#000}
.no-data{padding:20px;font-size:15px;font-weight:900;color:#555;text-align:center}
</style>
</head>
<body>
<div class="page">
  <div class="map-panel">
    <div class="map-header">
      <span class="map-title">JAPAN SEISMIC MAP</span>
      <span class="map-time" id="map-time">—</span>
    </div>
    <div class="map-wrap">
      <img class="map-img" src="data:image/png;base64," alt="Japan"/>
      <div id="epi-ring"></div>
      <div id="epi-marker"></div>
      <div id="epi-center"></div>
    </div>
    <div class="map-footer">
      <span>✛ Epicentre</span>
      <span>USGS LIVE DATA</span>
    </div>
  </div>
 
  <div class="data-panel">
    <div class="data-header">
      <span class="monitor-label">EARTHQUAKE MONITOR</span>
      <span class="live-badge"><div class="live-dot"></div>LIVE</span>
    </div>
    <div class="main-quake">
      <div class="mag-row">
        <span class="mag-label">Magnitude</span>
        <span class="mag-value" id="main-mag">—</span>
        <span class="mag-unit">M</span>
      </div>
      <div class="quake-location" id="main-loc">Loading data...</div>
      <div class="quake-meta">
        <span class="quake-time" id="main-time"></span>
        <span class="quake-depth" id="main-depth"></span>
      </div>
    </div>
    <div class="scale-section">
      <div class="section-label">Magnitude Scale Reference</div>
      <div class="scale-bar">
        <div class="scale-seg" style="background:#aaa">M1</div>
        <div class="scale-seg" style="background:#888">M2</div>
        <div class="scale-seg" style="background:#666">M3</div>
        <div class="scale-seg" style="background:#444">M4</div>
        <div class="scale-seg" style="background:#222">M5</div>
        <div class="scale-seg" style="background:#000">M6+</div>
      </div>
    </div>
    <div class="recent-section">
      <div class="recent-label">Recent Earthquakes — Japan Region</div>
      <div class="quake-list" id="quake-list"><div class="no-data">Fetching...</div></div>
    </div>
  </div>
</div>
<script>
const GEO={minLat:24,maxLat:46,minLon:122,maxLon:146};
function toPos(lat,lon){
  return{
    x:((lon-GEO.minLon)/(GEO.maxLon-GEO.minLon)*100),
    y:((GEO.maxLat-lat)/(GEO.maxLat-GEO.minLat)*100)
  };
}
function ago(ms){const s=(Date.now()-ms)/1000;if(s<60)return Math.round(s)+'s ago';if(s<3600)return Math.round(s/60)+'m ago';if(s<86400)return Math.round(s/3600)+'h ago';return Math.round(s/86400)+'d ago';}
function grey(m){if(m<2)return'#aaa';if(m<3)return'#888';if(m<4)return'#666';if(m<5)return'#444';if(m<6)return'#222';return'#000';}
async function load(){
  try{
    const r=await fetch('https://earthquake.usgs.gov/fdsnws/event/1/query?format=geojson&minlatitude=24&maxlatitude=46&minlongitude=122&maxlongitude=146&minmagnitude=1.5&orderby=time&limit=9');
    const d=await r.json();
    const qs=d.features||[];
    if(!qs.length){document.getElementById('main-loc').textContent='No recent earthquakes';document.getElementById('quake-list').innerHTML='<div class="no-data">No data.</div>';return;}
    const t=qs[0];
    const mag=parseFloat(t.properties.mag).toFixed(1);
    const lon=t.geometry.coordinates[0],lat=t.geometry.coordinates[1],dep=parseFloat(t.geometry.coordinates[2]).toFixed(0);
    document.getElementById('main-mag').textContent=mag;
    document.getElementById('main-loc').textContent=t.properties.place||'Japan Region';
    document.getElementById('main-time').textContent=ago(t.properties.time);
    document.getElementById('main-depth').textContent='Depth: '+dep+' km';
    document.getElementById('map-time').textContent=new Date(t.properties.time).toLocaleDateString('en-US',{month:'short',day:'numeric',hour:'2-digit',minute:'2-digit'});
    const p=toPos(lat,lon);
    ['epi-ring','epi-marker','epi-center'].forEach(id=>{const el=document.getElementById(id);el.style.display='block';el.style.left=p.x+'%';el.style.top=p.y+'%';});
    const recent=qs.slice(1,6);
    document.getElementById('quake-list').innerHTML=recent.map(q=>{
      const m=parseFloat(q.properties.mag),pct=Math.min(100,(m/8)*100),c=grey(m),dep2=parseFloat(q.geometry.coordinates[2]).toFixed(0);
      return '<div class="q-row"><div class="q-mag" style="color:'+c+'">'+m.toFixed(1)+'</div><div class="q-info"><div class="q-loc">'+(q.properties.place||'Japan Region')+'</div><div class="q-sub"><span>'+ago(q.properties.time)+'</span><span>Depth: '+dep2+' km</span></div></div><div class="q-mbar"><div class="q-mbar-track"><div class="q-mbar-fill" style="width:'+pct+'%;background:'+c+'"></div></div></div></div>';
    }).join('');
  }catch(e){document.getElementById('main-loc').textContent='Connection error';document.getElementById('quake-list').innerHTML='<div class="no-data">Could not load data.</div>';}
}
load();
</script>
</body>
</html>
